# pagespeak environment variables
#
# Copy to `.env` (gitignored). `bin/run` auto-sources `.env` if present.
# Anything already in the environment WINS over `.env`: an inline
# `PAGESPEAK_VISION_BACKEND=openrouter bin/run convert ...` and exports
# from your shell rc both take precedence — `.env` only fills vars that
# are otherwise unset.
#
# Each var has a corresponding constructor arg and CLI flag — those
# always win over the env var.

# ─── Anthropic API key — only when vision_backend=anthropic (not the default) ─
# Get one at https://console.anthropic.com/. Ignored when
# vision_backend=claude_code (uses your Claude Code session) or
# vision_backend=openrouter (uses OPENROUTER_API_KEY).
# ANTHROPIC_API_KEY=sk-ant-...

# ─── Optional: OpenRouter unified billing for vision pass ──────────────────
# Only needed if you set vision_backend="openrouter".
# OPENROUTER_API_KEY=sk-or-v1-...

# ─── Per-task model selection: see config/model_router.yaml ────────────────
# Model + sampling kwargs (max_tokens, temperature, etc.) for
# each task × backend live in `config/model_router.yaml`. The legacy
# env vars `PAGESPEAK_VISION_MODEL` and `PAGESPEAK_NORMALIZE_HEADINGS_MODEL`
# are no longer consulted — edit the YAML to change per-task models.
# Per-call CLI flags (`--vision-model`, `--normalize-headings-model`) and
# constructor kwargs still win as the highest-precedence selector.

# ─── llm_full mode token-budget gate: see config/model_router.yaml ─────────
# The `agents.heading_normalize_full.max_input_tokens` YAML key caps
# the assembled "all headings + body anchors" prompt size for
# `--normalize-headings-mode llm_full`. The legacy
# `PAGESPEAK_NORMALIZE_HEADINGS_MAX_INPUT_TOKENS` env var is no longer
# consulted — edit the YAML to retune.

# ─── Optional: per-image worker pool size for the vision pass ──────────────
# Each worker runs an independent backend call (phash + cache + LLM +
# cache write). Total wall-clock scales as `total_images / concurrency`.
# Default 6. Override per-call with `to_markdown(vision_concurrency=…)`
# or `--vision-concurrency`. Sensible ceilings:
#   - claude_code: 4-8 (each `claude --print` is its own python+model load)
#   - anthropic API: 16-32 (network-bound, rate-limited by tier)
#   - openrouter: 8-16
# PAGESPEAK_VISION_CONCURRENCY=6

# ─── Optional: phased-pipeline parallel chunk worker count ─────────────────
# Default 1. Used by `pagespeak ingest` and `pagespeak convert` (chunked-parallel PDF).
# PAGESPEAK_WORKERS=1

# ─── Optional: `claude --print` subprocess timeout for heading-normalize ───
# Heading-normalize sends the document's heading list (plus body anchors
# under `llm_full`) to Opus via `claude --print`. Default 1800s (30 min).
# Bump if a very large `llm_full` payload (hundreds of pages, ~400K+ tokens)
# hits the cap; drop if you want faster
# failure on hung calls. Used only when the per-task backend is
# `claude_code` (the default).
# PAGESPEAK_CLAUDE_CODE_TIMEOUT_S=1800

# ─── Optional: `claude --print` subprocess timeout for vision pass ─────────
# Vision is per-image (one `claude --print` per diagram), so 120s is
# usually plenty. Bump for large diagrams or slow networks; drop for
# faster failure on hung calls. Distinct from the heading-normalize
# timeout above (whole-doc, much larger payload).
# PAGESPEAK_VISION_CLAUDE_CODE_TIMEOUT_S=120

# ─── Optional: pages per chunk in `--workers` parallel ingest ──────────────
# When `--workers > 1`, Marker ingests the PDF in N-page chunks across
# worker processes. Default 50. Smaller chunks = finer-grained resume on
# failure; larger chunks = fewer Marker model-loads (~30s each) but more
# per-worker RAM.
# PAGESPEAK_CHUNK_PAGES=50

# ─── Optional: download remote images during HTML ingest ───────────────────
# HTML sources reference images by remote URL (`<img src="https://…">`);
# MarkItDown keeps them remote and never downloads them, so the vision pass
# can't see HTML figures. On by default: HTML ingest downloads each remote
# image into `images/<name>` and retargets the ref to the local path. Set to
# 0 to leave images as external URLs (no download, no vision on them). Files
# already on disk are reused, not re-fetched.
# PAGESPEAK_DOWNLOAD_REMOTE_IMAGES=1

# ─── Optional: copy local sibling images during ingest ─────────────────────
# An HTML bundle (saved webpage / doc-site export) ships the document plus a
# sibling `images/` dir with relative refs; nothing used to copy those files,
# so the vision pass (which only reads `<out>/images/`) saw nothing. On by
# default: HTML/markdown ingest copies each locally-resolvable ref into
# `<out>/images/` (refs outside the source's own dir are ignored). Set to 0 to
# leave refs pointing at the source tree.
# PAGESPEAK_COPY_LOCAL_IMAGES=1

# ─── Optional: per-image timeout for remote-image download ─────────────────
# Per-request HTTP timeout (seconds) when downloading a remote HTML image.
# Default 30. Bump on slow networks or large figures.
# PAGESPEAK_REMOTE_IMAGE_TIMEOUT_S=30

# ─── Optional: max size for one downloaded remote image ────────────────────
# Hard cap (bytes) on a single remote image download; a larger image is skipped
# (its ref kept remote, nothing written) so a hostile or oversized figure can't
# fill disk or the vision payload. Default 26214400 (25 MiB).
# PAGESPEAK_REMOTE_IMAGE_MAX_BYTES=26214400

# ─── Optional: structure phase — flat-source H1 demote threshold ──────────
# `structure` phase pass `_flat_source_demote`. Conservative: only fires on
# runs of N+ consecutive H1s with no intervening H2-H6 heading. Default 5.
# Lower to catch shorter clusters; raise to be more conservative.
# PAGESPEAK_FLAT_H1_THRESHOLD=5

# ─── Optional: structure phase — orphan-H1 rebalance threshold ─────────────
# `structure` phase pass `_h1_ratio_rebalance`. Percent of H1s (excluding
# the title) that must be "orphans" (no H2 between this H1 and the next H1)
# for the rebalance to fire. Default 70. Catches machine-flattened HTML-export
# PDFs (every help article published as a sibling `# Title`) while sparing
# authored-flat docs at lower orphan ratios. Drop to 50 to be aggressive;
# raise to 80+ to be conservative.
# PAGESPEAK_ORPHAN_H1_RATIO_THRESHOLD=70

# ─── Optional: default torch device for PDF backends ───────────────────────
# Pin the torch device (`cpu` / `mps` / `cuda`) once instead of typing
# `--device cpu` on every call. Use case: Apple Silicon machines that
# hit the surya/MPS crash (`torch.AcceleratorError: index ... out of
# bounds` in surya's vision encoder) should set this to `cpu` once and
# forget. Default unset = backend picks (Marker autodetects MPS on
# Apple Silicon, which is where the crash bites). Explicit `--device`
# / `device=` kwarg still wins. Applies to both Marker and Docling.
# PAGESPEAK_DEFAULT_DEVICE=cpu

# ─── Optional: CLI log level ───────────────────────────────────────────────
# Controls verbosity of pagespeak's own logger output during CLI runs:
# vision_progress, vision_cache_stats, heading_normalize_*, split_*.
# Levels (low → high): DEBUG / INFO / WARNING / ERROR.
# Default INFO. Library consumers (apps that embed pagespeak) configure
# their own logging — this env var only affects `bin/run convert ...`
# and the other CLI subcommands.
# PAGESPEAK_LOG_LEVEL=INFO

# ─── Optional: per-task LLM backend selection ──────────────────────────────
# Each LLM-using task picks its backend independently. Values:
#   claude_code  — local CLI, $0 under an active Claude Code session
#   anthropic    — direct Anthropic API (needs ANTHROPIC_API_KEY)
#   openrouter   — unified billing via OpenRouter (needs OPENROUTER_API_KEY)
# Per-call CLI flags / kwargs override these env vars. A value that isn't
# one of the three falls back to the default (claude_code).
# PAGESPEAK_VISION_BACKEND=claude_code
# PAGESPEAK_HEADING_NORMALIZE_BACKEND=claude_code
# PAGESPEAK_HEADING_NORMALIZE_FULL_BACKEND=claude_code

# ─── Optional: LLM call tracking DB ────────────────────────────────────────
# pagespeak writes every LLM call (vision + heading_normalize +
# heading_normalize_full) to pf-core's `llm_runs` table for cost
# tracking and audit. Default sink is a SQLite file at
# `~/.pagespeak/llm_tracking.db` — no setup required. Point at
# postgres or mysql to share the table across tools.
#
# pf-core's `llm_runs` schema is shared across pf-core-based tools;
# pointing several of them at the same DATABASE_URL gives one
# cross-project cost-tracking view.
#
# Tracking is opt-in for library consumers: only `pagespeak`'s CLI
# initializes the DB at startup. From Python, call
# `pagespeak._db.init_db()` before your first `to_markdown()`.
# DATABASE_URL=sqlite:///~/.pagespeak/llm_tracking.db
# DATABASE_URL=postgresql://user:pass@localhost:5432/llm_tracking
# DATABASE_URL=mysql+pymysql://user:pass@localhost:3306/llm_tracking
